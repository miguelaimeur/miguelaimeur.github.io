<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Semillas Lorem — Tienda Online</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --verde: #2d5016;
    --verde-claro: #4a7c2a;
    --verde-suave: #e8f0de;
    --crema: #faf8f2;
    --tierra: #8b5e3c;
    --texto: #1a1a1a;
    --texto-suave: #5a5a5a;
    --borde: #d8e4c8;
    --blanco: #ffffff;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--crema);
    color: var(--texto);
    line-height: 1.6;
  }

  /* ─── HEADER ─── */
  header {
    background: var(--verde);
    color: white;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    letter-spacing: 0.02em;
  }

  .logo span {
    color: #b5d96e;
  }

  nav a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    margin-left: 2rem;
    font-size: 0.9rem;
    font-weight: 400;
    transition: color 0.2s;
  }
  nav a:hover { color: white; }

  .header-icons {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }

  .icon-btn {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    border-radius: 50px;
    padding: 0.4rem 0.9rem;
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 0.2s;
  }
  .icon-btn:hover { background: rgba(255,255,255,0.2); }

  /* ─── HERO ─── */
  .hero {
    background: linear-gradient(135deg, var(--verde) 0%, var(--verde-claro) 60%, #6a9e3a 100%);
    color: white;
    padding: 6rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  .hero-text h1 em {
    font-style: italic;
    color: #b5d96e;
  }

  .hero-text p {
    font-size: 1.05rem;
    opacity: 0.85;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .btn-primary {
    background: #b5d96e;
    color: var(--verde);
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    margin-right: 1rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.2); }

  .btn-outline {
    background: transparent;
    color: white;
    border: 1.5px solid rgba(255,255,255,0.5);
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .btn-outline:hover { border-color: white; }

  .hero-image {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
  }

  /* ─── CATEGORÍAS ─── */
  .section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--verde);
    margin-bottom: 0.4rem;
  }

  .section-sub {
    color: var(--texto-suave);
    font-size: 0.95rem;
    margin-bottom: 2.5rem;
  }

  .categorias {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .categoria {
    background: white;
    border: 1px solid var(--borde);
    border-radius: 14px;
    padding: 1.8rem 1.2rem;
    text-align: center;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .categoria:hover { transform: translateY(-4px); box-shadow: 0 6px 24px rgba(45,80,22,0.1); }

  .cat-emoji { font-size: 2.4rem; margin-bottom: 0.8rem; }

  .cat-nombre {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--verde);
    margin-bottom: 0.3rem;
  }

  .cat-count {
    font-size: 0.8rem;
    color: var(--texto-suave);
  }

  /* ─── PRODUCTOS DESTACADOS ─── */
  .productos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .producto {
    background: white;
    border: 1px solid var(--borde);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .producto:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(45,80,22,0.12); }

  .producto-img {
    background: var(--verde-suave);
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    position: relative;
  }

  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--tierra);
    color: white;
    font-size: 0.72rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge.nuevo { background: var(--verde); }
  .badge.oferta { background: #c0392b; }

  .producto-info {
    padding: 1.2rem;
  }

  .producto-nombre {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--texto);
    margin-bottom: 0.3rem;
  }

  .producto-sub {
    font-size: 0.82rem;
    color: var(--texto-suave);
    margin-bottom: 1rem;
  }

  .producto-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .precio {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--verde);
  }

  .precio-original {
    font-size: 0.85rem;
    text-decoration: line-through;
    color: #aaa;
    margin-left: 0.4rem;
  }

  .btn-carrito {
    background: var(--verde);
    color: white;
    border: none;
    padding: 0.5rem 1.1rem;
    border-radius: 50px;
    font-size: 0.82rem;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-carrito:hover { background: var(--verde-claro); }

  /* ─── BANNER ENVÍOS ─── */
  .banner-envios {
    background: var(--verde);
    color: white;
    padding: 3rem 2rem;
  }

  .banner-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .envio-item h3 {
    font-size: 1.5rem;
    margin-bottom: 0.3rem;
  }
  .envio-item p { font-size: 0.88rem; opacity: 0.8; }

  /* ─── NEWSLETTER ─── */
  .newsletter {
    background: var(--verde-suave);
    border-top: 1px solid var(--borde);
    border-bottom: 1px solid var(--borde);
    padding: 3.5rem 2rem;
    text-align: center;
  }

  .newsletter h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: var(--verde);
    margin-bottom: 0.5rem;
  }

  .newsletter p {
    color: var(--texto-suave);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    max-width: 440px;
    margin: 0 auto;
  }

  .newsletter-form input {
    flex: 1;
    padding: 0.75rem 1.2rem;
    border: 1.5px solid var(--borde);
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    background: white;
    outline: none;
  }

  .newsletter-form input:focus { border-color: var(--verde); }

  /* ─── FOOTER ─── */
  footer {
    background: #1a2e0a;
    color: rgba(255,255,255,0.75);
    padding: 3rem 2rem 1.5rem;
  }

  .footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: white;
    margin-bottom: 0.8rem;
  }

  .footer-logo span { color: #b5d96e; }

  .footer-desc {
    font-size: 0.85rem;
    line-height: 1.7;
    max-width: 260px;
  }

  .footer-col h4 {
    color: white;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .footer-col a {
    display: block;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.88rem;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: white; }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1.2rem;
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding: 3rem 1.2rem; }
    .hero-text h1 { font-size: 2.2rem; }
    .hero-image { display: none; }
    .categorias { grid-template-columns: repeat(2, 1fr); }
    .productos { grid-template-columns: 1fr; }
    .banner-inner { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
    nav { display: none; }
  }
</style>
</head>
