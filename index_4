    .hero-triangle { width:80px;height:80px;margin-bottom:2.5rem;opacity:0;animation:fadeDown .8s .1s forwards; }
    .hero-triangle svg { width:100%;height:100%; }

    .hero-name {
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(4.5rem,14vw,13rem);
      line-height:.88;letter-spacing:.06em;
      opacity:0;animation:fadeDown .9s .3s forwards;
    }
    .hero-name .line1 {
      display:block;color:transparent;
      -webkit-text-stroke:1.5px var(--crimson);
      text-shadow:0 0 40px rgba(232,0,61,.3),0 0 100px rgba(232,0,61,.1);
    }
    .hero-name .line2 {
      display:block;color:var(--gold);
      text-shadow:0 0 30px rgba(201,168,76,.25);
    }

    .hero-roles {
      display:flex;gap:2rem;margin-top:2rem;align-items:center;
      opacity:0;animation:fadeDown .8s .55s forwards;
    }
    .hero-roles span { font-size:.75rem;letter-spacing:.5em;text-transform:uppercase;color:var(--muted); }
    .hero-roles .dot { color:var(--gold);font-size:.5rem; }

    /* SOCIAL BAR */
    .social-bar {
      margin-top:3rem;
      display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem;
      opacity:0;animation:fadeDown .8s .75s forwards;
    }
    .section-bar {
      margin-top:1.25rem;
      display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem;
      opacity:0;animation:fadeDown .8s .9s forwards;
    }
    .soc-link {
      display:flex;align-items:center;gap:.5rem;
      padding:.55rem 1.1rem;
      border:1px solid rgba(201,168,76,.25);
      color:var(--gold);text-decoration:none;
      font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.15em;
      transition:border-color .3s,background .3s,color .3s;
      cursor:none;position:relative;overflow:hidden;
    }
    .soc-link::before {
      content:'';position:absolute;inset:0;
      background:var(--crimson);transform:scaleX(0);transform-origin:left;
      transition:transform .3s ease;z-index:0;
    }
    .soc-link:hover::before { transform:scaleX(1); }
    .soc-link:hover { color:var(--white);border-color:var(--crimson); }
    .soc-link span,.soc-icon { position:relative;z-index:1; }
    .soc-icon { font-size:1rem; }
    .section-link {
      padding:.55rem 1.1rem;
      border:1px solid rgba(232,0,61,.22);
      color:var(--white);text-decoration:none;
      font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.15em;
      transition:border-color .3s,background .3s,color .3s;
      cursor:none;background:rgba(232,0,61,.04);
    }
    .section-link:hover {
      border-color:var(--gold);
      background:rgba(201,168,76,.08);
      color:var(--gold);
    }

    .scroll-hint {
      position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
      display:flex;flex-direction:column;align-items:center;gap:.5rem;
      font-size:.55rem;letter-spacing:.4em;text-transform:uppercase;color:var(--muted);
      opacity:0;animation:fadeDown .6s 1.2s forwards;
    }
    .scroll-arrow {
      width:1px;height:40px;
      background:linear-gradient(to bottom,var(--gold),transparent);
      animation:scrollPulse 2s 1.5s infinite;
    }
    @keyframes scrollPulse { 0%,100%{opacity:.3;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.2)} }

    /* SECTIONS */
    section { padding:7rem 2rem; }
    .section-eyebrow { font-size:.6rem;letter-spacing:.5em;text-transform:uppercase;color:var(--crimson);margin-bottom:1rem; }
    .section-title { font-family:'Bebas Neue',sans-serif;font-size:clamp(2.8rem,6vw,6rem);line-height:.92;letter-spacing:.04em; }
    .reveal { opacity:0;transform:translateY(28px);transition:opacity .75s ease,transform .75s ease; }
    .reveal.vis { opacity:1;transform:translateY(0); }

    /* PLAYER */
    .player-section { background:var(--black2);border-top:1px solid rgba(201,168,76,.1);border-bottom:1px solid rgba(201,168,76,.1); }
    .player-inner { max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:5rem;align-items:center; }
    .player-info .section-title { color:var(--white);margin-bottom:1rem; }
    .player-info .section-title em { color:var(--gold);font-style:normal; }
    .player-info p { font-size:1.05rem;line-height:1.9;color:var(--muted);font-weight:300;margin-bottom:2rem; }

    .player-frame {
      position:relative;padding:1px;
      background:linear-gradient(135deg,var(--gold) 0%,var(--crimson) 50%,transparent 100%);
    }
    .player-frame::before {
      content:'';position:absolute;inset:-1px;
      background:linear-gradient(135deg,var(--gold),var(--crimson),transparent);
      z-index:-1;filter:blur(8px);opacity:.4;
    }
    .player-frame iframe { display:block;width:100%;height:200px;border:none;background:#000; }

    .playlist-tabs { display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap; }
    .ptab {
      padding:.4rem 1rem;font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.15em;
