    /* PROYECTOS */
    .projects-inner { max-width:1100px;margin:0 auto; }
    .proj-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(201,168,76,.08);margin-top:3rem; }
    .proj-card {
      background:var(--black);padding:2.5rem 2rem;position:relative;overflow:hidden;
      transition:background .3s;text-decoration:none;color:var(--white);display:block;cursor:none;
    }
    .proj-card::after {
      content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
      background:linear-gradient(90deg,var(--crimson),var(--gold));
      transform:scaleX(0);transform-origin:left;transition:transform .4s ease;
    }
    .proj-card:hover { background:var(--black2); }
    .proj-card:hover::after { transform:scaleX(1); }
    .proj-num { font-family:'Bebas Neue',sans-serif;font-size:.8rem;color:var(--crimson);letter-spacing:.3em;margin-bottom:1.2rem;opacity:.6; }
    .proj-title { font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:.08em;margin-bottom:.75rem;color:var(--gold); }
    .proj-desc { font-size:.85rem;line-height:1.8;color:var(--muted);font-weight:300; }
    .proj-arrow { margin-top:1.5rem;font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:var(--crimson); }

    /* CONTACT */
    .contact-section { background:var(--black2);border-top:1px solid rgba(201,168,76,.1); }
    .contact-inner { max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center; }
    .contact-big { font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,5rem);line-height:1.05; }
    .contact-big a { color:var(--crimson);text-decoration:none;text-shadow:0 0 30px rgba(232,0,61,.3);transition:color .3s; }
    .contact-big a:hover { color:var(--gold); }
    .contact-sub { font-size:1rem;line-height:2;color:var(--muted);font-weight:300;margin-top:2rem; }
    .contact-sub strong { color:var(--white); }

    .btn-contact {
      display:inline-block;margin-top:2rem;padding:1rem 2.5rem;
      border:1px solid var(--gold);color:var(--gold);
      font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.25em;
      text-decoration:none;cursor:none;transition:all .3s;position:relative;overflow:hidden;
    }
    .btn-contact::before {
      content:'';position:absolute;inset:0;background:var(--gold);
      transform:scaleX(0);transform-origin:left;transition:transform .3s;z-index:0;
    }
    .btn-contact:hover { color:var(--black); }
    .btn-contact:hover::before { transform:scaleX(1); }
    .btn-contact span { position:relative;z-index:1; }

    /* FOOTER */
    footer { border-top:1px solid rgba(201,168,76,.12);padding:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem; }
    footer p { font-size:.55rem;letter-spacing:.25em;text-transform:uppercase;color:var(--muted);opacity:.4; }
    .footer-logo { font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.3em;color:transparent;-webkit-text-stroke:1px rgba(201,168,76,.3); }

    @keyframes fadeDown { from{opacity:0;transform:translateY(-15px)}to{opacity:1;transform:translateY(0)} }

    @media(max-width:768px){
      .player-inner,.about-inner,.contact-inner{grid-template-columns:1fr;gap:3rem;}
      .proj-grid{grid-template-columns:1fr;}
      .hero-name{font-size:clamp(3.5rem,20vw,7rem);}
      section{padding:5rem 1.5rem;}
      footer{flex-direction:column;text-align:center;}
    }
  </style>
</head>
