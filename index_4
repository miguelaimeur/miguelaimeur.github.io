    .gold-line { width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent); }

    /* HERO */
    .hero {
      min-height:100vh;
      display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;
      position:relative;padding:6rem 2rem 4rem;overflow:hidden;
    }
    .hero::before {
      content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
      width:700px;height:400px;
      background:radial-gradient(ellipse,rgba(232,0,61,.06) 0%,transparent 70%);
