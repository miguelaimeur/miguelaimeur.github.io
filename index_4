    .festivals-inner { max-width:1100px;margin:0 auto; }
    .fest-grid { display:flex;flex-wrap:wrap;gap:.6rem;margin-top:2.5rem; }
    .fest-tag { padding:.5rem 1.1rem;border:1px solid rgba(201,168,76,.15);font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);transition:all .3s;cursor:none; }
