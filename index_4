  <script>
    // Cursor
    const cur=document.getElementById('cur'),cur2=document.getElementById('cur2');
    let mx=0,my=0,rx=0,ry=0;
    document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
    (function loop(){
      cur.style.left=mx+'px';cur.style.top=my+'px';
      rx+=(mx-rx)*.13;ry+=(my-ry)*.13;
      cur2.style.left=rx+'px';cur2.style.top=ry+'px';
      requestAnimationFrame(loop);
    })();

    // Scroll reveal
    const obs=new IntersectionObserver(els=>{
      els.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');});
    },{threshold:.12});
    document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

    // Player tabs
    function loadAudio(id,btn){
      document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
      btn.classList.add('active');
      const src = id==='channel'
        ? 'https://www.ivoox.com/podcast-dance-pec_sq_f12741467_1.html'
        : 'https://www.ivoox.com/player_ej_159255588_6_1.html?c1=040c09';
      if(id==='channel') window.open(src,'_blank');
      else document.getElementById('ivoox-player').src=src;
    }
  </script>
